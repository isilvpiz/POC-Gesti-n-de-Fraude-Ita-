# AWS — autenticación recomendada: perfil/SSO (NO access keys en texto plano)
AWS_PROFILE=default
AWS_REGION=us-east-1

# Bedrock — inference profile de Claude 3.5 Haiku (ID válido)
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MAX_TOKENS=1000

# Directorios locales
INPUT_EMAIL_DIR=input/emails
OUTPUT_DIR=output

# Regla de negocio
PLAZO_MAXIMO_RECLAMO_DIAS=30

# Logging
LOG_LEVEL=INFO
